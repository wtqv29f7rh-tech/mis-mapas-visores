<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Editor de Mapas Freeplane</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #2c3e50;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .toolbar {
            background: #34495e;
            color: white;
            padding: 10px;
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            border-bottom: 2px solid #e74c3c;
        }
        button {
            background: #3498db;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
        }
        button.primary { background: #27ae60; }
        button.warning { background: #e67e22; }
        button.danger { background: #e74c3c; }
        button.small { padding: 4px 8px; font-size: 11px; }
        .stats {
            background: #ecf0f1;
            padding: 6px 10px;
            font-size: 11px;
            color: #7f8c8d;
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 6px;
        }
        
        /* Panel de archivos */
        .file-panel {
            background: white;
            margin: 10px;
            padding: 10px;
            border-radius: 8px;
        }
        .file-list {
            max-height: 150px;
            overflow-y: auto;
            margin-top: 8px;
        }
        .file-item {
            padding: 8px;
            border-bottom: 1px solid #ecf0f1;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
        }
        .file-item:hover { background: #e8f4fd; }
        
        /* Editor de nodo */
        .edit-panel {
            background: white;
            margin: 10px;
            padding: 10px;
            border-radius: 8px;
            display: none;
        }
        .edit-panel.show { display: block; }
        .edit-textarea {
            width: 100%;
            padding: 8px;
            font-size: 14px;
            border: 1px solid #bdc3c7;
            border-radius: 6px;
            margin: 8px 0;
        }
        
        /* Editor de nota richcontent */
        .note-editor {
            background: white;
            margin: 10px;
            padding: 10px;
            border-radius: 8px;
            display: none;
        }
        .note-editor.show { display: block; }
        .note-toolbar {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
            margin-bottom: 8px;
            padding-bottom: 8px;
            border-bottom: 1px solid #ecf0f1;
        }
        .note-content {
            width: 100%;
            min-height: 120px;
            padding: 8px;
            border: 1px solid #bdc3c7;
            border-radius: 6px;
            font-size: 12px;
            background: white;
        }
        .note-content:focus { outline: none; border-color: #3498db; }
        
        /* Visor del mapa */
        .map-viewer {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
            background: #f5f5f5;
        }
        .tree { list-style: none; }
        .tree-node { margin: 2px 0; position: relative; }
        .node-row {
            display: flex;
            align-items: flex-start;
            padding: 6px 8px;
            background: white;
            border-radius: 6px;
            border-left: 3px solid #3498db;
            margin: 2px 0;
            position: relative;
        }
        .node-row.editing { background: #fff9e6; border-left-color: #e67e22; }
        .toggle-btn {
            width: 22px;
            background: #3498db;
            color: white;
            border-radius: 4px;
            text-align: center;
            margin-right: 8px;
            cursor: pointer;
            font-size: 11px;
        }
        .node-text { flex: 1; font-size: 13px; word-break: break-word; cursor: pointer; }
        .node-text.editable:hover { background: #ecf0f1; }
        .node-actions {
            display: none;
            gap: 4px;
            margin-left: 8px;
        }
        .node-row:hover .node-actions { display: flex; }
        .action-btn {
            background: #ecf0f1;
            border: none;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 10px;
            cursor: pointer;
        }
        .children { margin-left: 20px; border-left: 2px dotted #bdc3c7; }
        .children.collapsed { display: none; }
        .note-indicator {
            background: #f39c12;
            color: white;
            border-radius: 50%;
            width: 16px;
            text-align: center;
            font-size: 9px;
            cursor: pointer;
            margin-left: 4px;
        }
        .note-preview {
            margin: 4px 0 0 28px;
            padding: 6px;
            background: #fff9e6;
            border-left: 3px solid #f39c12;
            font-size: 11px;
            display: none;
        }
        .note-preview.show { display: block; }
        .loading { text-align: center; padding: 30px; color: #7f8c8d; }
        .error { color: #e74c3c; padding: 15px; text-align: center; background: #fee; margin: 10px; border-radius: 8px; }
        .hidden { display: none; }
        
        @media (max-width: 600px) {
            .toolbar button { padding: 5px 10px; font-size: 11px; }
            .node-actions { display: flex; opacity: 0.5; }
        }
    </style>
</head>
<body>
    <div class="toolbar">
        <button id="openLocalBtn" class="primary">📂 Abrir .mm</button>
        <button id="saveBtn" class="warning">💾 Guardar como</button>
        <button id="addChildBtn" disabled>➕ Hijo</button>
        <button id="addSiblingBtn" disabled>📎 Hermano</button>
        <button id="deleteBtn" disabled>🗑️ Eliminar</button>
        <button onclick="expandAll()">📖 Expandir</button>
        <button onclick="collapseAll()">📕 Colapsar</button>
    </div>
    <div class="stats" id="stats">💡 Abre un archivo .mm para editarlo</div>
    
    <!-- Panel de selección de archivo -->
    <div id="filePanel" class="file-panel">
        <input type="file" id="fileInput" accept=".mm" style="display:none">
        <div id="fileListContainer"></div>
    </div>
    
    <!-- Editor de texto de nodo -->
    <div id="editPanel" class="edit-panel">
        <strong>✏️ Editar texto del nodo</strong>
        <input type="text" id="editTextInput" class="edit-textarea">
        <button id="saveTextBtn" style="background:#27ae60;">Guardar</button>
        <button id="cancelTextBtn">Cancelar</button>
    </div>
    
    <!-- Editor de nota richcontent -->
    <div id="noteEditor" class="note-editor">
        <strong>📝 Editar nota (HTML)</strong>
        <div class="note-toolbar">
            <button class="small" data-format="bold">N</button>
            <button class="small" data-format="italic">C</button>
            <button class="small" data-format="underline">S</button>
            <button class="small" data-format="insertUnorderedList">•</button>
            <button class="small" data-format="insertOrderedList">1.</button>
            <button class="small" data-format="indent">→</button>
            <button class="small" data-format="outdent">←</button>
        </div>
        <div id="noteContent" class="note-content" contenteditable="true"></div>
        <div style="margin-top:8px; display:flex; gap:8px;">
            <button id="saveNoteBtn" style="background:#27ae60;">Guardar nota</button>
            <button id="cancelNoteBtn">Cancelar</button>
            <button id="clearNoteBtn" class="danger small">Eliminar nota</button>
        </div>
    </div>
    
    <div class="map-viewer" id="viewer">
        <div class="loading">📁 Pulsa "Abrir .mm" y selecciona tu archivo</div>
    </div>

    <script>
        // ========== VARIABLES GLOBALES ==========
        let rootNode = null;
        let allNodes = new Map();
        let currentNodeId = 1;
        let currentNodeEditing = null;
        let currentNoteEditing = null;
        let originalXmlString = '';
        
        // Elementos DOM
        const openLocalBtn = document.getElementById('openLocalBtn');
        const fileInput = document.getElementById('fileInput');
        const saveBtn = document.getElementById('saveBtn');
        const addChildBtn = document.getElementById('addChildBtn');
        const addSiblingBtn = document.getElementById('addSiblingBtn');
        const deleteBtn = document.getElementById('deleteBtn');
        const editPanel = document.getElementById('editPanel');
        const noteEditor = document.getElementById('noteEditor');
        const editTextInput = document.getElementById('editTextInput');
        const saveTextBtn = document.getElementById('saveTextBtn');
        const cancelTextBtn = document.getElementById('cancelTextBtn');
        const saveNoteBtn = document.getElementById('saveNoteBtn');
        const cancelNoteBtn = document.getElementById('cancelNoteBtn');
        const clearNoteBtn = document.getElementById('clearNoteBtn');
        const noteContent = document.getElementById('noteContent');
        const statsDiv = document.getElementById('stats');
        const viewerDiv = document.getElementById('viewer');
        
        // ========== CARGA DE ARCHIVO LOCAL ==========
        openLocalBtn.onclick = () => fileInput.click();
        
        fileInput.onchange = (event) => {
            const file = event.target.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = (e) => {
                originalXmlString = e.target.result;
                const cleaned = sanitizeXml(originalXmlString);
                parseMindMap(cleaned);
                statsDiv.innerHTML = `✅ Editando: ${file.name} | ${allNodes.size} nodos`;
                enableEditing(true);
            };
            reader.readAsText(file);
            fileInput.value = '';
        };
        
        // ========== GUARDAR COMO ==========
        saveBtn.onclick = () => {
            if (!rootNode) {
                alert('No hay ningún mapa cargado');
                return;
            }
            const newXml = generateXml();
            downloadFile(newXml, 'mapa_editado.mm');
            statsDiv.innerHTML = '💾 Archivo guardado. Reemplaza el original en Drive si quieres.';
        };
        
        function downloadFile(content, filename) {
            const blob = new Blob([content], { type: 'application/xml' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = filename;
            link.click();
            URL.revokeObjectURL(link.href);
        }
        
        // ========== GENERAR XML DESDE EL ÁRBOL ==========
        function generateXml() {
            let xml = '<?xml version="1.0" encoding="UTF-8"?>\n';
            xml += '<map version="freeplane 1.8.0">\n';
            xml += generateNodeXml(rootNode, 0);
            xml += '</map>';
            return xml;
        }
        
        function generateNodeXml(node, level) {
            const indent = '  '.repeat(level + 1);
            const foldedAttr = node.folded ? ' FOLDED="true"' : ' FOLDED="false"';
            const linkAttr = node.link ? ` LINK="${escapeHtml(node.link)}"` : '';
            let xml = `${indent}<node TEXT="${escapeHtml(node.text)}"${foldedAttr}${linkAttr} ID="${node.id}" CREATED="1" MODIFIED="1">\n`;
            
            if (node.note && node.note.trim()) {
                xml += `${indent}  <richcontent TYPE="NOTE">\n`;
                xml += `${indent}    <html>\n`;
                xml += `${indent}      <head></head>\n`;
                xml += `${indent}      <body>\n`;
                xml += `${indent}        ${node.note}\n`;
                xml += `${indent}      </body>\n`;
                xml += `${indent}    </html>\n`;
                xml += `${indent}  </richcontent>\n`;
            }
            
            node.children.forEach(child => {
                xml += generateNodeXml(child, level + 1);
            });
            
            xml += `${indent}</node>\n`;
            return xml;
        }
        
        // ========== FUNCIONES DE EDICIÓN ==========
        function editNodeText(nodeId) {
            const node = allNodes.get(nodeId);
            if (!node) return;
            currentNodeEditing = nodeId;
            editTextInput.value = node.text;
            editPanel.classList.add('show');
            editTextInput.focus();
        }
        
        saveTextBtn.onclick = () => {
            if (!currentNodeEditing) return;
            const node = allNodes.get(currentNodeEditing);
            if (node) {
                node.text = editTextInput.value;
                updateNodeDisplay(currentNodeEditing);
                editPanel.classList.remove('show');
                currentNodeEditing = null;
                statsDiv.innerHTML = `✅ Texto actualizado. No olvides guardar.`;
            }
        };
        
        cancelTextBtn.onclick = () => {
            editPanel.classList.remove('show');
            currentNodeEditing = null;
        };
        
        function editNodeNote(nodeId) {
            const node = allNodes.get(nodeId);
            if (!node) return;
            currentNoteEditing = nodeId;
            noteContent.innerHTML = node.note || '';
            noteEditor.classList.add('show');
        }
        
        saveNoteBtn.onclick = () => {
            if (!currentNoteEditing) return;
            const node = allNodes.get(currentNoteEditing);
            if (node) {
                node.note = noteContent.innerHTML;
                updateNoteDisplay(currentNoteEditing);
                noteEditor.classList.remove('show');
                currentNoteEditing = null;
                statsDiv.innerHTML = `✅ Nota actualizada. No olvides guardar.`;
            }
        };
        
        cancelNoteBtn.onclick = () => {
            noteEditor.classList.remove('show');
            currentNoteEditing = null;
        };
        
        clearNoteBtn.onclick = () => {
            if (!currentNoteEditing) return;
            noteContent.innerHTML = '';
        };
        
        // Formato para el editor de notas
        document.querySelectorAll('[data-format]').forEach(btn => {
            btn.onclick = () => {
                const format = btn.getAttribute('data-format');
                document.execCommand(format, false, null);
                noteContent.focus();
            };
        });
        
        function addChildNode(nodeId) {
            const parent = allNodes.get(nodeId);
            if (!parent) return;
            const newNode = {
                id: `ID_${Date.now()}_${Math.random()}`,
                text: 'Nuevo nodo',
                link: null,
                folded: false,
                note: null,
                children: [],
                level: parent.level + 1
            };
            parent.children.push(newNode);
            allNodes.set(newNode.id, newNode);
            renderMap();
            statsDiv.innerHTML = `➕ Nodo hijo añadido. No olvides guardar.`;
        }
        
        function addSiblingNode(nodeId) {
            const node = allNodes.get(nodeId);
            if (!node || !node.parentId) return;
            const parent = allNodes.get(node.parentId);
            const index = parent.children.findIndex(c => c.id === nodeId);
            const newNode = {
                id: `ID_${Date.now()}_${Math.random()}`,
                text: 'Nuevo hermano',
                link: null,
                folded: false,
                note: null,
                children: [],
                level: node.level
            };
            parent.children.splice(index + 1, 0, newNode);
            allNodes.set(newNode.id, newNode);
            renderMap();
            statsDiv.innerHTML = `➕ Nodo hermano añadido. No olvides guardar.`;
        }
        
        function deleteNode(nodeId) {
            const node = allNodes.get(nodeId);
            if (!node || !node.parentId) return;
            if (node.children.length > 0 && !confirm('Este nodo tiene hijos. ¿Eliminar también sus hijos?')) return;
            const parent = allNodes.get(node.parentId);
            const index = parent.children.findIndex(c => c.id === nodeId);
            parent.children.splice(index, 1);
            
            // Eliminar recursivamente hijos del mapa
            function deleteChildren(n) {
                n.children.forEach(c => {
                    allNodes.delete(c.id);
                    deleteChildren(c);
                });
            }
            deleteChildren(node);
            allNodes.delete(nodeId);
            renderMap();
            statsDiv.innerHTML = `🗑️ Nodo eliminado. No olvides guardar.`;
        }
        
        function updateNodeDisplay(nodeId) {
            const nodeElement = document.querySelector(`.tree-node[data-id="${nodeId}"] .node-text`);
            if (nodeElement) {
                nodeElement.textContent = allNodes.get(nodeId).text;
            }
        }
        
        function updateNoteDisplay(nodeId) {
            const noteElement = document.querySelector(`.note-preview[data-note-preview="${nodeId}"]`);
            if (noteElement) {
                noteElement.innerHTML = allNodes.get(nodeId).note || '';
            }
        }
        
        function enableEditing(enabled) {
            addChildBtn.disabled = !enabled;
            addSiblingBtn.disabled = !enabled;
            deleteBtn.disabled = !enabled;
        }
        
        // ========== PROCESAMIENTO DEL MAPA (igual que antes) ==========
        function sanitizeXml(str) {
            if (!str) return '';
            const entities = { '&nbsp;': '&#160;', '&lt;': '&#60;', '&gt;': '&#62;', '&quot;': '&#34;', '&apos;': '&#39;' };
            for (const [ent, rep] of Object.entries(entities)) str = str.split(ent).join(rep);
            return str;
        }
        
        function parseMindMap(xmlString) {
            const parser = new DOMParser();
            const xmlDoc = parser.parseFromString(xmlString, "text/xml");
            const error = xmlDoc.querySelector('parsererror');
            if (error) throw new Error(error.textContent);
            
            const raiz = xmlDoc.querySelector('map > node');
            if (!raiz) throw new Error('No se encontró el nodo raíz');
            
            allNodes.clear();
            rootNode = parseNode(raiz, null, 0);
            renderMap();
        }
        
        function parseNode(xmlNode, parentId, level) {
            const id = xmlNode.getAttribute('ID') || `ID_${currentNodeId++}`;
            const text = xmlNode.getAttribute('TEXT') || 'Sin título';
            const link = xmlNode.getAttribute('LINK') || null;
            const folded = xmlNode.getAttribute('FOLDED') === 'true';
            let note = null;
            const rich = xmlNode.querySelector(':scope > richcontent[TYPE="NOTE"]');
            if (rich) {
                const htmlContent = rich.querySelector('html');
                if (htmlContent) note = htmlContent.innerHTML;
            }
            const node = { id, text, link, folded, note, parentId, level, children: [] };
            allNodes.set(id, node);
            const hijos = xmlNode.querySelectorAll(':scope > node');
            hijos.forEach(h => {
                const child = parseNode(h, id, level + 1);
                node.children.push(child);
            });
            return node;
        }
        
        function renderMap() {
            if (!rootNode) return;
            viewerDiv.innerHTML = `<ul class="tree">${renderNode(rootNode)}</ul>`;
            attachEvents();
        }
        
        function renderNode(node) {
            const hasChildren = node.children && node.children.length > 0;
            const hasNote = node.note && node.note.trim().length > 0;
            const toggleIcon = hasChildren ? '▼' : '•';
            let childrenHtml = '';
            if (hasChildren) {
                const collapsedClass = node.folded ? 'collapsed' : '';
                childrenHtml = `<ul class="children ${collapsedClass}">`;
                node.children.forEach(child => { childrenHtml += renderNode(child); });
                childrenHtml += `</ul>`;
            }
            return `
                <li class="tree-node" data-id="${node.id}">
                    <div class="node-row">
                        <span class="toggle-btn" data-toggle="${node.id}">${toggleIcon}</span>
                        <span class="node-text editable" data-link="${node.link || ''}">${escapeHtml(node.text)}</span>
                        ${hasNote ? `<span class="note-indicator" data-note="${node.id}">📝</span>` : ''}
                        <div class="node-actions">
                            <button class="action-btn edit-text" data-id="${node.id}">✏️</button>
                            <button class="action-btn edit-note" data-id="${node.id}">📋</button>
                            <button class="action-btn add-child" data-id="${node.id}">➕</button>
                            <button class="action-btn add-sibling" data-id="${node.id}">📎</button>
                            <button class="action-btn delete-node" data-id="${node.id}">🗑️</button>
                        </div>
                    </div>
                    ${hasNote ? `<div class="note-preview" data-note-preview="${node.id}">${node.note || ''}</div>` : ''}
                    ${childrenHtml}
                </li>
            `;
        }
        
        function attachEvents() {
            // Toggle de nodos
            document.querySelectorAll('[data-toggle]').forEach(el => {
                el.onclick = (e) => {
                    e.stopPropagation();
                    const id = el.getAttribute('data-toggle');
                    const children = document.querySelector(`li[data-id="${id}"] > .children`);
                    if (children) {
                        children.classList.toggle('collapsed');
                        el.textContent = children.classList.contains('collapsed') ? '▶' : '▼';
                    }
                };
            });
            
            // Mostrar/ocultar notas
            document.querySelectorAll('[data-note]').forEach(el => {
                el.onclick = (e) => {
                    e.stopPropagation();
                    const id = el.getAttribute('data-note');
                    const note = document.querySelector(`[data-note-preview="${id}"]`);
                    if (note) note.classList.toggle('show');
                };
            });
            
            // Editar texto (haciendo clic en el texto o en el botón)
            document.querySelectorAll('.node-text, .edit-text').forEach(el => {
                el.onclick = (e) => {
                    e.stopPropagation();
                    let nodeId = el.getAttribute('data-id');
                    if (!nodeId) {
                        nodeId = el.closest('.node-row')?.querySelector('.edit-text')?.getAttribute('data-id');
                    }
                    if (nodeId) editNodeText(nodeId);
                };
            });
            
            // Editar nota
            document.querySelectorAll('.edit-note').forEach(el => {
                el.onclick = (e) => {
                    e.stopPropagation();
                    const nodeId = el.getAttribute('data-id');
                    if (nodeId) editNodeNote(nodeId);
                };
            });
            
            // Añadir hijo
            document.querySelectorAll('.add-child').forEach(el => {
                el.onclick = (e) => {
                    e.stopPropagation();
                    const nodeId = el.getAttribute('data-id');
                    if (nodeId && confirm('¿Añadir nodo hijo?')) addChildNode(nodeId);
                };
            });
            
            // Añadir hermano
            document.querySelectorAll('.add-sibling').forEach(el => {
                el.onclick = (e) => {
                    e.stopPropagation();
                    const nodeId = el.getAttribute('data-id');
                    if (nodeId && confirm('¿Añadir nodo hermano?')) addSiblingNode(nodeId);
                };
            });
            
            // Eliminar nodo
            document.querySelectorAll('.delete-node').forEach(el => {
                el.onclick = (e) => {
                    e.stopPropagation();
                    const nodeId = el.getAttribute('data-id');
                    if (nodeId && confirm('¿Eliminar este nodo?')) deleteNode(nodeId);
                };
            });
            
            // Enlaces
            document.querySelectorAll('[data-link]').forEach(el => {
                const link = el.getAttribute('data-link');
                if (link && link !== 'null' && link !== '') {
                    el.style.cursor = 'pointer';
                    el.onclick = (e) => {
                        e.stopPropagation();
                        if (link.startsWith('#')) {
                            const dest = document.querySelector(`li[data-id="${link.substring(1)}"]`);
                            if (dest) dest.scrollIntoView({ behavior: 'smooth' });
                        } else if (link.startsWith('http')) {
                            window.open(link, '_blank');
                        }
                    };
                }
            });
        }
        
        function expandAll() {
            document.querySelectorAll('.children').forEach(el => el.classList.remove('collapsed'));
            document.querySelectorAll('[data-toggle]').forEach(el => { if (el.textContent === '▶') el.textContent = '▼'; });
        }
        
        function collapseAll() {
            document.querySelectorAll('.children').forEach(el => el.classList.add('collapsed'));
            document.querySelectorAll('[data-toggle]').forEach(el => { if (el.textContent === '▼') el.textContent = '▶'; });
        }
        
        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            }).replace(/"/g, '&quot;');
        }
    </script>
</body>
</html>
